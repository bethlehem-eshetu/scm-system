@model IEnumerable<SCM_System.Models.Entities.TenderBid>

@{
    ViewData["Title"] = "My Submitted Bids";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-file-invoice-dollar text-primary me-2"></i>My Active Bids</h2>
        <a asp-controller="Tender" asp-action="AvailableTenders" class="btn btn-outline-primary shadow-sm"><i class="fas fa-search me-1"></i> Browse More Tenders</a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white border rounded shadow-sm">
            <i class="fas fa-folder-open fa-4x text-muted mb-3 opacity-50"></i>
            <h4 class="text-muted">You haven't submitted any bids yet.</h4>
            <p class="text-muted mb-4">Look for available tenders in the marketplace to start bidding.</p>
            <a asp-controller="Tender" asp-action="AvailableTenders" class="btn btn-primary px-4">Find Opportunities</a>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th>Tender Title</th>
                                <th>Category</th>
                                <th>My Unit Bid</th>
                                <th>Delivery Quote</th>
                                <th>Submitted On</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var bid in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-dark">
                                        <div class="text-truncate" style="max-width: 250px;" title="@bid.Tender.Title">
                                            @bid.Tender.Title
                                        </div>
                                    </td>
                                    <td><span class="badge bg-secondary">@bid.Tender.Category?.CategoryName</span></td>
                                    <td class="fw-bold">@bid.BidAmount.ToString("C")</td>
                                    <td class="text-muted">@bid.DeliveryTimeline</td>
                                    <td><small class="text-muted">@bid.SubmittedDate.ToString("MMM dd, yyyy")</small></td>
                                    <td>
                                        @if (bid.Status == "Pending")
                                        {
                                            <span class="badge bg-warning text-dark"><i class="fas fa-hourglass-half me-1"></i>Pending</span>
                                        }
                                        else if (bid.Status == "Accepted")
                                        {
                                            <span class="badge bg-success"><i class="fas fa-check me-1"></i>Won</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger"><i class="fas fa-times me-1"></i>Lost</span>
                                        }
                                    </td>
                                    <td class="text-end">
                                        <a asp-controller="Tender" asp-action="Details" asp-route-id="@bid.TenderId" class="btn btn-sm btn-outline-secondary">Tender Details</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
