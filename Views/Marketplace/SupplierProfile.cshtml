@model SCM_System.Models.Entities.User

@{
    ViewData["Title"] = "Supplier Profile";
}

<div class="container mt-4">
    <div class="mb-3">
        <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-left me-1"></i>Back to Marketplace</a>
    </div>

    <!-- Supplier Header Banner -->
    <div class="card border-0 shadow-sm mb-5 overflow-hidden">
        <div class="bg-primary text-white p-5 position-relative">
            <!-- Decorative background elements -->
            <div class="position-absolute opacity-25" style="top: -50px; right: -50px; font-size: 200px;">
                <i class="fas fa-building"></i>
            </div>
            
            <div class="position-relative z-1 d-flex flex-column flex-md-row align-items-md-center gap-4">
                <div class="bg-white rounded-circle d-flex justify-content-center align-items-center shadow p-1" style="width: 120px; height: 120px;">
                    <i class="fas fa-industry fa-4x text-primary"></i>
                </div>
                <div>
                    <h1 class="fw-bold mb-1">@Model.Supplier?.CompanyName</h1>
                    <div class="d-flex flex-wrap gap-3 mt-2 fs-6 opacity-75">
                        <span><i class="fas fa-map-marker-alt me-2 text-warning"></i>@Model.Supplier?.City</span>
                        <span><i class="fas fa-envelope me-2 text-warning"></i>@Model.Email</span>
                        <span><i class="fas fa-phone me-2 text-warning"></i>@Model.PhoneNumber</span>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="card-body bg-light p-4 d-flex justify-content-around">
            <div class="text-center">
                <h6 class="text-muted text-uppercase fw-bold mb-1 fs-7">Account Status</h6>
                @if (Model.Supplier?.VerificationStatus == "Verified") {
                    <span class="badge bg-success px-3 py-2 fs-6"><i class="fas fa-check-circle me-1"></i> Verified Partner</span>
                } else {
                    <span class="badge bg-warning text-dark px-3 py-2 fs-6"><i class="fas fa-clock me-1"></i> Verification Pending</span>
                }
            </div>
            <div class="border-end"></div>
            <div class="text-center">
                <h6 class="text-muted text-uppercase fw-bold mb-1 fs-7">Products Available</h6>
                <span class="fs-4 fw-bold text-dark">@(Model.Supplier?.Products?.Count ?? 0)</span>
            </div>
            <div class="border-end"></div>
            <div class="text-center">
                <h6 class="text-muted text-uppercase fw-bold mb-1 fs-7">Joined System</h6>
                <span class="fs-5 text-dark">@Model.CreatedAt.ToString("MMM yyyy")</span>
            </div>
        </div>
    </div>

    <!-- Supplier Product Catalog -->
    <div class="mb-4 d-flex justify-content-between align-items-center">
        <h3 class="fw-bold"><i class="fas fa-boxes text-primary me-2"></i>Product Catalog</h3>
    </div>

    @if (Model.Supplier?.Products == null || !Model.Supplier.Products.Any())
    {
        <div class="alert alert-light border shadow-sm p-5 text-center">
            <i class="fas fa-box-open fa-3x text-muted mb-3 opacity-50"></i>
            <h5 class="text-muted">This supplier hasn't listed any products yet.</h5>
        </div>
    }
    else
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4 mb-5">
            @foreach (var product in Model.Supplier.Products)
            {
                var inStock = (product.Inventory?.QuantityAvailable ?? 0) > 0;
                
                <div class="col">
                    <div class="card h-100 border-0 shadow-sm hover-shadow transition-all position-relative overflow-hidden">
                        @if (!inStock)
                        {
                            <div class="position-absolute top-0 start-0 w-100 h-100 bg-light opacity-50 z-1"></div>
                            <div class="position-absolute top-0 end-0 bg-danger text-white px-4 py-1 fw-bold shadow-sm z-2" style="transform: rotate(45deg) translate(25px, -15px); width: 150px; text-align: center;">
                                SOLD OUT
                            </div>
                        }

                        <div class="card-header bg-white border-bottom-0 pb-0 pt-3">
                            <span class="badge bg-secondary mb-2">@product.Category?.CategoryName</span>
                            <h5 class="card-title fw-bold text-dark mb-1">@product.ProductName</h5>
                        </div>

                        <div class="card-body">
                            <div class="fs-4 fw-bold text-success mb-3">@product.BasePrice.ToString("C")</div>
                            <p class="card-text text-muted small">@product.Description</p>
                        </div>

                        <div class="card-footer bg-transparent border-top d-flex justify-content-between align-items-center p-3" style="position: relative; z-index: 3;">
                            <span class="text-muted small fw-bold">
                                @if (inStock) { <span class="text-success"><i class="fas fa-check-circle me-1"></i> @(product.Inventory?.QuantityAvailable ?? 0) in stock</span> }
                                else { <span class="text-danger"><i class="fas fa-times-circle me-1"></i> Out of stock</span> }
                            </span>
                            
                            @if (inStock)
                            {
                                <a asp-controller="PurchaseOrder" asp-action="Create" asp-route-supplierId="@Model.Id" asp-route-productId="@product.Id" class="btn btn-primary btn-sm fw-bold">
                                    Buy Now
                                </a>
                            }
                            else
                            {
                                <button class="btn btn-secondary btn-sm disabled" disabled>Buy Now</button>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    .hover-shadow:hover {
        transform: translateY(-4px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.15)!important;
    }
    .transition-all {
        transition: all .25s ease-in-out;
    }
    .fs-7 { font-size: 0.85rem; }
    .z-1 { z-index: 1; }
    .z-2 { z-index: 2; }
</style>
