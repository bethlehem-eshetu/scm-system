@model IEnumerable<SCM_System.Models.Entities.Product>

@{
    ViewData["Title"] = "Direct Purchase Marketplace";
}

<div class="container-fluid mt-4">
    <div class="row">
        <!-- Sidebar Filters -->
        <div class="col-lg-3 col-md-4 mb-4">
            <div class="card shadow-sm border-0 sticky-top" style="top: 20px; z-index: 1000;">
                <div class="card-header bg-primary text-white py-3">
                    <h5 class="mb-0 fw-bold"><i class="fas fa-filter me-2"></i>Filters</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Index" method="get">
                        
                        <!-- Search Keyword -->
                        <div class="mb-4">
                            <label class="form-label fw-bold small text-uppercase text-muted">Search Keyword</label>
                            <input type="text" name="searchString" value="@ViewData["CurrentSearch"]" class="form-control" placeholder="Product or Supplier name...">
                        </div>

                        <!-- Category -->
                        <div class="mb-4">
                            <label class="form-label fw-bold small text-uppercase text-muted">Category</label>
                            <select name="categoryId" class="form-select">
                                <option value="">All Categories</option>
                                @foreach (var cat in ViewBag.Categories)
                                {
                                    <option value="@cat.Id" selected="@((int?)ViewData["CurrentCategory"] == cat.Id)">@cat.Name</option>
                                }
                            </select>
                        </div>

                        <!-- Availability -->
                        <div class="mb-4">
                            <label class="form-label fw-bold small text-uppercase text-muted">Availability</label>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="availabilityFilter" id="availAll" value="" checked="@(string.IsNullOrEmpty((string)ViewData["CurrentAvailability"]))">
                                <label class="form-check-label" for="availAll">Any Availability</label>
                            </div>
                            <div class="form-check mb-2">
                                <input class="form-check-input" type="radio" name="availabilityFilter" id="availInStock" value="InStock" checked="@((string)ViewData["CurrentAvailability"] == "InStock")">
                                <label class="form-check-label text-success" for="availInStock">In Stock Only</label>
                            </div>
                            <div class="form-check">
                                <input class="form-check-input" type="radio" name="availabilityFilter" id="availOutStock" value="OutOfStock" checked="@((string)ViewData["CurrentAvailability"] == "OutOfStock")">
                                <label class="form-check-label text-danger" for="availOutStock">Out of Stock</label>
                            </div>
                        </div>

                        <!-- Price Range Max -->
                        <div class="mb-4">
                            <label class="form-label fw-bold small text-uppercase text-muted">Max Price (ETB)</label>
                            <input type="number" step="100" min="0" name="maxPrice" value="@ViewData["CurrentPrice"]" class="form-control" placeholder="e.g. 5000">
                        </div>

                        <!-- Location -->
                        <div class="mb-4 border-bottom pb-4">
                            <label class="form-label fw-bold small text-uppercase text-muted">Location</label>
                            <input type="text" name="locationFilter" value="@ViewData["CurrentLocation"]" class="form-control" placeholder="e.g. Addis Ababa">
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary fw-bold shadow-sm">Apply Filters</button>
                            <a asp-action="Index" class="btn btn-light text-muted btn-sm mt-1">Clear Filters</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Product Grid -->
        <div class="col-lg-9 col-md-8">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h2><i class="fas fa-store text-primary me-2"></i>Supplier Marketplace</h2>
                <span class="text-muted">Showing <strong>@Model.Count()</strong> results</span>
            </div>

            @if (!Model.Any())
            {
                <div class="alert alert-warning shadow-sm p-4 text-center">
                    <i class="fas fa-search fa-3x text-warning mb-3 opacity-75"></i>
                    <h5>No products match your search criteria.</h5>
                    <p class="mb-0 text-muted">Try removing some filters to see more results.</p>
                </div>
            }
            else
            {
                <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
                    @foreach (var product in Model)
                    {
                        var inStock = (product.Inventory?.QuantityAvailable ?? 0) > 0;
                        
                        <div class="col">
                            <div class="card h-100 border-0 shadow-sm hover-shadow transition-all position-relative">
                                @if (!inStock)
                                {
                                    <div class="position-absolute top-50 start-50 translate-middle w-100 h-100 bg-white opacity-50 z-1" style="border-radius: .375rem;"></div>
                                    <span class="position-absolute top-50 start-50 translate-middle badge bg-danger px-4 py-2 fs-5 shadow z-2" style="transform: translate(-50%, -50%) rotate(-15deg);">
                                        OUT OF STOCK
                                    </span>
                                }

                                <div class="card-header bg-white border-bottom-0 pt-3 pb-0 d-flex justify-content-between align-items-start">
                                    <span class="badge bg-primary-subtle text-primary border border-primary-subtle rounded-pill px-3 py-1">
                                        @product.Category?.CategoryName
                                    </span>
                                    <span class="fw-bold fs-5 text-success">@product.BasePrice.ToString("C")</span>
                                </div>

                                <div class="card-body">
                                    <h5 class="card-title fw-bold text-dark mb-1">@product.ProductName</h5>
                                    
                                    <div class="d-flex align-items-center mb-3">
                                        <i class="fas fa-building text-muted me-2 small"></i>
                                        <a asp-action="SupplierProfile" asp-route-id="@product.SupplierId" class="text-decoration-none text-secondary fw-bold small hover-primary" style="position: relative; z-index: 3;">
                                            @product.Supplier.CompanyName
                                        </a>
                                    </div>

                                    <p class="card-text text-muted small" style="display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 2.8em;">
                                        @product.Description
                                    </p>

                                    <div class="d-flex justify-content-between align-items-center mt-3 pt-3 border-top">
                                        <div class="text-muted small">
                                            <i class="fas fa-map-marker-alt me-1 text-danger"></i> @product.Supplier?.City
                                        </div>
                                        <div>
                                            @if (inStock) {
                                                <span class="badge bg-success-subtle text-success"><i class="fas fa-box-open me-1"></i> @(product.Inventory?.QuantityAvailable ?? 0) in stock</span>
                                            }
                                        </div>
                                    </div>
                                </div>

                                <div class="card-footer bg-transparent border-top-0 pb-3" style="position: relative; z-index: 3;">
                                    @if (inStock)
                                    {
                                        <a asp-controller="PurchaseOrder" asp-action="Create" asp-route-supplierId="@product.SupplierId" asp-route-productId="@product.Id" class="btn btn-primary w-100 fw-bold shadow-sm">
                                            <i class="fas fa-shopping-cart me-2"></i> Buy Direct
                                        </a>
                                    }
                                    else
                                    {
                                        <button class="btn btn-secondary w-100 fw-bold disabled" disabled>
                                            <i class="fas fa-ban me-2"></i> Unavailable
                                        </button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>

<style>
    .hover-shadow:hover {
        transform: translateY(-4px);
        box-shadow: 0 1rem 3rem rgba(0,0,0,.15)!important;
    }
    .hover-primary:hover {
        color: var(--bs-primary) !important;
        text-decoration: underline !important;
    }
    .transition-all {
        transition: all .25s ease-in-out;
    }
    .z-1 { z-index: 1; }
    .z-2 { z-index: 2; }
</style>
