@model SCM_System.Models.Entities.Product

@{
    ViewData["Title"] = "Product Details";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb bg-light p-3 rounded shadow-sm">
            <li class="breadcrumb-item"><a asp-action="MyProducts" class="text-decoration-none">Dashboard</a></li>
            <li class="breadcrumb-item active" aria-current="page">Product Details</li>
        </ol>
    </nav>

    <div class="row">
        <!-- Product Image -->
        <div class="col-md-5 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body d-flex flex-column align-items-center justify-content-center bg-light rounded p-4">
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img src="@Model.ImageUrl" alt="@Model.ProductName" class="img-fluid rounded shadow" style="max-height: 400px; width: auto; object-fit: contain;" />
                    }
                    else
                    {
                        <div class="text-center text-muted p-5 d-flex flex-column align-items-center h-100 justify-content-center">
                            <i class="bi bi-image display-1 mb-3 opacity-50"></i>
                            <h4>No Image Available</h4>
                            <p>Upload an image in the edit screen to help customers see your product.</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Product Information -->
        <div class="col-md-7 mb-4">
            <div class="card shadow-sm border-0 h-100">
                <div class="card-body p-4 position-relative">
                    
                    @if (Model.IsAvailable)
                    {
                        <span class="badge bg-success position-absolute top-0 end-0 m-4 fs-6 py-2 px-3 shadow-sm rounded-pill">Available</span>
                    }
                    else
                    {
                        <span class="badge bg-danger position-absolute top-0 end-0 m-4 fs-6 py-2 px-3 shadow-sm rounded-pill">Out of Stock</span>
                    }

                    <p class="text-muted text-uppercase fw-bold m-0 small tracking-wider">@Model.Category.CategoryName</p>
                    <h2 class="display-6 fw-bolder mb-3 text-dark">@Model.ProductName</h2>
                    
                    <div class="d-flex align-items-baseline mb-4 text-primary">
                        <span class="h1 mb-0 fw-bold me-2">@Model.BasePrice.ToString("N2")</span>
                        <span class="fs-4 text-muted">ETB</span>
                    </div>

                    <div class="row g-3 mb-4 bg-light rounded p-3 me-2 ms-0 shadow-sm">
                        <div class="col-sm-4">
                            <div class="text-muted small fw-bold text-uppercase mb-1">Current Stock</div>
                            <div class="fs-5 fw-bold @(Model.Quantity == 0 ? "text-danger" : "text-success")">
                                <i class="bi @(Model.Quantity == 0 ? "bi-x-circle" : "bi-check-circle") me-1"></i>
                                @Model.Quantity @Model.Unit
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="text-muted small fw-bold text-uppercase mb-1">SKU Code</div>
                            <div class="fs-5 text-dark fw-bold font-monospace">
                                @(string.IsNullOrEmpty(Model.SKU) ? "N/A" : Model.SKU)
                            </div>
                        </div>
                        <div class="col-sm-4">
                            <div class="text-muted small fw-bold text-uppercase mb-1">Date Added</div>
                            <div class="fs-6 text-dark mt-1">
                                <i class="bi bi-calendar3 me-1"></i> @Model.CreatedAt.ToString("MMM dd, yyyy")
                            </div>
                        </div>
                    </div>

                    <h5 class="fw-bold mb-3 border-bottom pb-2">Description</h5>
                    <div class="bg-white rounded p-3 mb-4" style="min-height: 120px; font-size: 1.05rem; line-height: 1.6; color: #495057; white-space: pre-wrap;">
                        @(string.IsNullOrEmpty(Model.Description) ? "No description provided." : Model.Description)
                    </div>

                    <div class="d-flex gap-2 pt-3 border-top mt-auto">
                        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary px-4 py-2 fw-bold text-uppercase" style="letter-spacing: 0.5px;">
                            <i class="bi bi-pencil-square me-2"></i> Edit Product
                        </a>
                        <button type="button" class="btn btn-outline-danger px-4 py-2 fw-bold text-uppercase" data-bs-toggle="modal" data-bs-target="#deleteModal" style="letter-spacing: 0.5px;">
                            <i class="bi bi-trash3 me-2"></i> Delete
                        </button>
                    </div>

                </div>
            </div>
        </div>
    </div>
</div>

<!-- Delete Modal -->
<div class="modal fade" id="deleteModal" tabindex="-1" aria-labelledby="deleteModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-danger text-white border-0">
                <h5 class="modal-title fw-bold" id="deleteModalLabel">Confirm Delete</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <i class="bi bi-exclamation-triangle display-1 text-warning mb-3 d-block"></i>
                <h4 class="mb-3">Are you sure?</h4>
                <p class="text-muted mb-0">Do you really want to delete <strong>@Model.ProductName</strong>? This action cannot be undone.</p>
            </div>
            <div class="modal-footer border-0 justify-content-center bg-light">
                <button type="button" class="btn btn-secondary px-4 py-2" data-bs-dismiss="modal">Cancel</button>
                <form asp-action="Delete" asp-route-id="@Model.Id" method="post" class="d-inline">
                    <button type="submit" class="btn btn-danger px-4 py-2 fw-bold shadow-sm">Delete Product</button>
                </form>
            </div>
        </div>
    </div>
</div>
