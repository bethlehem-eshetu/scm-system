@model IEnumerable<SCM_System.Models.Entities.Supplier>

@{
    ViewData["Title"] = "Rejected Suppliers";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Rejected Suppliers</h1>
        <div>
            <a asp-action="AllSuppliers" class="btn btn-primary me-2">
                <i class="fas fa-arrow-left"></i> Back to All Suppliers
            </a>
            <a asp-action="Dashboard" class="btn btn-secondary">
                <i class="fas fa-tachometer-alt"></i> Dashboard
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle me-2"></i> No rejected suppliers found.
        </div>
    }
    else
    {
        <div class="card shadow">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-striped table-hover" id="rejectedSuppliersTable">
                        <thead class="table-dark">
                            <tr>
                                <th>ID</th>
                                <th>Company Name</th>
                                <th>Contact Person</th>
                                <th>Email</th>
                                <th>Phone</th>
                                <th>Business Type</th>
                                <th>City</th>
                                <th>Rejected Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var supplier in Model)
                            {
                                <tr>
                                    <td>@supplier.Id</td>
                                    <td>@supplier.CompanyName</td>
                                    <td>@supplier.User?.FullName</td>
                                    <td>@supplier.User?.Email</td>
                                    <td>@supplier.User?.PhoneNumber</td>
                                    <td>@supplier.BusinessType</td>
                                    <td>@supplier.City</td>
                                    <td>@supplier.CreatedAt.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <a asp-action="SupplierDetails" asp-route-id="@supplier.Id" class="btn btn-info btn-sm">
                                            <i class="fas fa-eye"></i> View
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#rejectedSuppliersTable').DataTable({
                "pageLength": 25,
                "ordering": true
            });
        });
    </script>
}