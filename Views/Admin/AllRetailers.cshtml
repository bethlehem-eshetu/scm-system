@model IEnumerable<SCM_System.Models.Entities.Retailer>

@{
    ViewData["Title"] = "All Retailers";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>All Retailers</h1>
        <div>
            <a asp-action="Dashboard" class="btn btn-secondary">
                <i class="fas fa-arrow-left"></i> Back to Dashboard
            </a>
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="fas fa-exclamation-circle me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="card shadow">
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-striped table-hover" id="retailersTable">
                    <thead class="table-dark">
                        <tr>
                            <th>ID</th>
                            <th>Business Name</th>
                            <th>Contact Person</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Business Type</th>
                            <th>City</th>
                            <th>Status</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var retailer in Model)
                        {
                            <tr>
                                <td>@retailer.Id</td>
                                <td>@retailer.BusinessName</td>
                                <td>@retailer.User?.FullName</td>
                                <td>@retailer.User?.Email</td>
                                <td>@retailer.User?.PhoneNumber</td>
                                <td>@retailer.BusinessType</td>
                                <td>@retailer.City</td>
                                <td>
                                    @if (retailer.User != null)
                                    {
                                        if (retailer.User.IsApproved)
                                        {
                                            <span class="badge bg-success">Approved</span>
                                        }
                                        else if (retailer.User.AccountStatus == "Rejected")
                                        {
                                            <span class="badge bg-danger">Rejected</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning text-dark">Pending</span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">No User</span>
                                    }
                                </td>
                                <td>
                                    <a asp-action="RetailerDetails" asp-route-id="@retailer.Id" class="btn btn-info btn-sm">
                                        <i class="fas fa-eye"></i> View
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('#retailersTable').DataTable({
                "pageLength": 25,
                "ordering": true,
                "language": {
                    "search": "Search retailers:"
                }
            });
        });
    </script>
}