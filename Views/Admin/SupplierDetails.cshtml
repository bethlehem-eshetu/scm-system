@model SCM_System.Models.Entities.Supplier

@{
    ViewData["Title"] = "Supplier Details";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Supplier Details</h1>
        <div>
            <a asp-action="AllSuppliers" class="btn btn-primary me-2">
                <i class="fas fa-arrow-left"></i> Back to Suppliers
            </a>
            <a asp-action="Dashboard" class="btn btn-secondary">
                <i class="fas fa-tachometer-alt"></i> Dashboard
            </a>
        </div>
    </div>

    <div class="row">
        <!-- Supplier Information -->
        <div class="col-md-4">
            <div class="card shadow mb-4">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Company Information</h5>
                </div>
                <div class="card-body">
                    <table class="table table-sm">
                        <tr>
                            <th>Company Name:</th>
                            <td>@Model.CompanyName</td>
                        </tr>
                        <tr>
                            <th>Business Type:</th>
                            <td>@Model.BusinessType</td>
                        </tr>
                        <tr>
                            <th>License Number:</th>
                            <td>@Model.LicenseNumber</td>
                        </tr>
                        <tr>
                            <th>TIN:</th>
                            <td>@Model.TaxIdentificationNumber</td>
                        </tr>
                        <tr>
                            <th>Address:</th>
                            <td>@Model.CompanyAddress</td>
                        </tr>
                        <tr>
                            <th>City:</th>
                            <td>@Model.City</td>
                        </tr>
                        <tr>
                            <th>Country:</th>
                            <td>@Model.Country</td>
                        </tr>
                        <tr>
                            <th>Website:</th>
                            <td>
                                @if (!string.IsNullOrEmpty(Model.Website))
                                {
                                    <a href="@Model.Website" target="_blank">@Model.Website</a>
                                }
                                else
                                {
                                    <span>N/A</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>Status:</th>
                            <td>
                                @if (Model.VerificationStatus == "Verified")
                                {
                                    <span class="badge bg-success">Verified</span>
                                }
                                else if (Model.VerificationStatus == "Pending")
                                {
                                    <span class="badge bg-warning">Pending</span>
                                }
                                else if (Model.VerificationStatus == "Rejected")
                                {
                                    <span class="badge bg-danger">Rejected</span>
                                }
                            </td>
                        </tr>
                        <tr>
                            <th>Registered:</th>
                            <td>@Model.CreatedAt.ToString("MMM dd, yyyy")</td>
                        </tr>
                    </table>

                    @if (!string.IsNullOrEmpty(Model.LicenseFilePath))
                    {
                        <a asp-action="ViewLicense" asp-route-id="@Model.Id" class="btn btn-info w-100" target="_blank">
                            <i class="fas fa-file-pdf me-2"></i> View License Document
                        </a>
                    }
                </div>
            </div>

            <!-- Contact Information -->
            <div class="card shadow mb-4">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0">Contact Information</h5>
                </div>
                <div class="card-body">
                    @if (Model.User != null)
                    {
                        <table class="table table-sm">
                            <tr>
                                <th>Contact Person:</th>
                                <td>@Model.User.FullName</td>
                            </tr>
                            <tr>
                                <th>Email:</th>
                                <td><a href="mailto:@Model.User.Email">@Model.User.Email</a></td>
                            </tr>
                            <tr>
                                <th>Phone:</th>
                                <td>@Model.User.PhoneNumber</td>
                            </tr>
                            <tr>
                                <th>Account Status:</th>
                                <td>
                                    @if (Model.User.IsApproved)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning">Pending</span>
                                    }
                                </td>
                            </tr>
                        </table>
                    }
                </div>
            </div>

            <!-- Description -->
            @if (!string.IsNullOrEmpty(Model.Description))
            {
                <div class="card shadow mb-4">
                    <div class="card-header bg-secondary text-white">
                        <h5 class="mb-0">Company Description</h5>
                    </div>
                    <div class="card-body">
                        <p class="mb-0">@Model.Description</p>
                    </div>
                </div>
            }

            <!-- Action Buttons -->
            @if (Model.VerificationStatus == "Pending")
            {
                <div class="card shadow">
                    <div class="card-body">
                        <div class="d-flex justify-content-between">
                            <form asp-action="ApproveSupplier" asp-route-id="@Model.Id" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-success" onclick="return confirm('Approve this supplier?')">
                                    <i class="fas fa-check me-2"></i> Approve
                                </button>
                            </form>

                            <button type="button" class="btn btn-danger" data-bs-toggle="modal" data-bs-target="#rejectModal">
                                <i class="fas fa-times me-2"></i> Reject
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Statistics and Products -->
        <div class="col-md-8">
            <!-- Statistics Cards -->
            <div class="row mb-4">
                <div class="col-md-4">
                    <div class="card bg-primary text-white shadow">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-0">Total Products</h6>
                                    <h2 class="mb-0">@(Model.Products?.Count ?? 0)</h2>
                                </div>
                                <i class="fas fa-box fa-3x opacity-50"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card bg-success text-white shadow">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-0">Purchase Orders</h6>
                                    <h2 class="mb-0">@(Model.PurchaseOrders?.Count ?? 0)</h2>
                                </div>
                                <i class="fas fa-file-invoice fa-3x opacity-50"></i>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="card bg-warning text-white shadow">
                        <div class="card-body">
                            <div class="d-flex justify-content-between align-items-center">
                                <div>
                                    <h6 class="mb-0">Tenders</h6>
                                    <h2 class="mb-0">@(Model.Tenders?.Count ?? 0)</h2>
                                </div>
                                <i class="fas fa-gavel fa-3x opacity-50"></i>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Products List -->
            @if (Model.Products != null && Model.Products.Any())
            {
                <div class="card shadow mb-4">
                    <div class="card-header bg-dark text-white">
                        <h5 class="mb-0">Products</h5>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="table table-sm table-striped">
                                <thead>
                                    <tr>
                                        <th>Product Name</th>
                                        <th>Price</th>
                                        <th>SKU</th>
                                        <th>Created</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var product in Model.Products.Take(5))
                                    {
                                        <tr>
                                            <td>@product.ProductName</td>
                                            <td>@product.BasePrice.ToString("C")</td>
                                            <td>@product.SKU</td>
                                            <td>@product.CreatedAt.ToString("MMM dd, yyyy")</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Reject Modal -->
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-danger text-white">
                <h5 class="modal-title">Reject Supplier: @Model.CompanyName</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <form asp-action="RejectSupplier" asp-route-id="@Model.Id" method="post">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="rejectionReason" class="form-label">Rejection Reason</label>
                        <textarea class="form-control" id="rejectionReason" name="rejectionReason" rows="3" required></textarea>
                        <div class="form-text">This reason will be sent to the supplier.</div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-danger">Reject Supplier</button>
                </div>
            </form>
        </div>
    </div>
</div>