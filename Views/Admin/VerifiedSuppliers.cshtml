@model IEnumerable<SCM_System.Models.Entities.Supplier>

@{
    ViewData["Title"] = "Verified Suppliers";
}

<div class="container-fluid py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Verified Suppliers</h1>
        <a asp-action="Dashboard" class="btn btn-secondary">
            <i class="fas fa-arrow-left"></i> Back to Dashboard
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            No verified suppliers yet.
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Company Name</th>
                        <th>Contact Person</th>
                        <th>Email</th>
                        <th>Phone</th>
                        <th>Business Type</th>
                        <th>City</th>
                        <th>Verified Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var supplier in Model)
                    {
                        <tr>
                            <td>@supplier.CompanyName</td>
                            <td>@supplier.User?.FullName</td>
                            <td>@supplier.User?.Email</td>
                            <td>@supplier.User?.PhoneNumber</td>
                            <td>@supplier.BusinessType</td>
                            <td>@supplier.City</td>
                            <td>@supplier.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td>
                                <a asp-action="ViewLicense" asp-route-id="@supplier.Id" class="btn btn-info btn-sm" target="_blank">
                                    <i class="fas fa-file-pdf"></i> License
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>