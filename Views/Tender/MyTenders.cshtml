@model IEnumerable<SCM_System.Models.Entities.Tender>

@{
    ViewData["Title"] = "My Tenders";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="fas fa-folder-open text-primary me-2"></i>My Tenders</h2>
        <a asp-action="Create" class="btn btn-primary shadow-sm"><i class="fas fa-plus me-1"></i> New Tender</a>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5 bg-white border rounded shadow-sm">
            <i class="fas fa-file-contract fa-4x text-muted mb-3"></i>
            <h4 class="text-muted">You haven't created any tenders yet.</h4>
            <a asp-action="Create" class="btn btn-outline-primary mt-2">Publish your first tender</a>
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-light">
                            <tr>
                                <th>Title</th>
                                <th>Category</th>
                                <th>Quantity</th>
                                <th>Closing Date</th>
                                <th>Bids</th>
                                <th>Status</th>
                                <th class="text-end">Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="fw-bold text-primary">@item.Title</td>
                                    <td><span class="badge bg-secondary">@item.Category?.CategoryName</span></td>
                                    <td>@item.Quantity</td>
                                    <td>
                                        @if(item.ClosingDate < DateTime.Today && item.Status == "Open")
                                        {
                                            <span class="text-danger fw-bold">@item.ClosingDate.ToString("MMM dd, yyyy") <i class="fas fa-exclamation-circle" title="Expired!"></i></span>
                                        }
                                        else
                                        {
                                            @item.ClosingDate.ToString("MMM dd, yyyy")
                                        }
                                    </td>
                                    <td>
                                        <span class="badge bg-info rounded-pill">@(item.Bids?.Count ?? 0) Bids</span>
                                    </td>
                                    <td>
                                        @if (item.Status == "Open") { <span class="badge bg-success">Open</span> }
                                        else if (item.Status == "Closed") { <span class="badge bg-warning text-dark">Closed</span> }
                                        else if (item.Status == "Awarded") { <span class="badge bg-primary">Awarded</span> }
                                        else { <span class="badge bg-danger">Cancelled</span> }
                                    </td>
                                    <td class="text-end">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">Manage</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
