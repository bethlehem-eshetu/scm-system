@model SCM_System.Models.Entities.Tender

@{
    ViewData["Title"] = "Tender Details";
}

<div class="container mt-4">
    <div class="mb-3">
        <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm"><i class="fas fa-arrow-left me-1"></i>Back</a>
    </div>

    <div class="row">
        <!-- Tender Details Info Card -->
        <div class="col-lg-8">
            <div class="card shadow-sm border-0 mb-4">
                <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                    <h4 class="mb-0 fw-bold text-primary">@Model.Title</h4>
                    
                    @if (Model.Status == "Open") { <span class="badge bg-success px-3 py-2 fs-6">Open</span> }
                    else if (Model.Status == "Closed") { <span class="badge bg-warning text-dark px-3 py-2 fs-6">Closed</span> }
                    else if (Model.Status == "Awarded") { <span class="badge bg-primary px-3 py-2 fs-6">Awarded</span> }
                    else { <span class="badge bg-danger px-3 py-2 fs-6">Cancelled</span> }
                </div>
                <div class="card-body p-4">
                    <div class="row mb-4">
                        <div class="col-md-3 col-6 mb-3">
                            <h6 class="text-muted text-uppercase fw-bold fs-7 mb-1">Category</h6>
                            <p class="fs-5 mb-0"><i class="fas fa-tag text-secondary me-2"></i>@Model.Category?.CategoryName</p>
                        </div>
                        <div class="col-md-3 col-6 mb-3">
                            <h6 class="text-muted text-uppercase fw-bold fs-7 mb-1">Quantity</h6>
                            <p class="fs-5 mb-0 fw-bold">@Model.Quantity</p>
                        </div>
                        <div class="col-md-3 col-6 mb-3">
                            <h6 class="text-muted text-uppercase fw-bold fs-7 mb-1">Closing Date</h6>
                            <p class="fs-5 mb-0 @(Model.ClosingDate < DateTime.Today && Model.Status == "Open" ? "text-danger fw-bold" : "")">
                                <i class="far fa-calendar-alt text-secondary me-2"></i>@Model.ClosingDate.ToString("MMM dd, yyyy")
                            </p>
                        </div>
                        <div class="col-md-3 col-6 mb-3">
                            <h6 class="text-muted text-uppercase fw-bold fs-7 mb-1">Bids Received</h6>
                            <p class="fs-5 mb-0"><span class="badge bg-info rounded-pill">@(Model.Bids?.Count ?? 0)</span></p>
                        </div>
                    </div>

                    <hr class="text-muted opacity-25" />

                    <h6 class="text-muted text-uppercase fw-bold fs-7 mb-3 mt-4">Detailed Description / Requirements</h6>
                    <div class="bg-light p-4 rounded fs-6 text-dark" style="white-space: pre-wrap;">@Model.Description</div>
                    
                    @if (Context.Session.GetString("UserRole") == "Retailer" && Model.Status == "Open")
                    {
                        <div class="mt-4 pt-3 border-top d-flex justify-content-end gap-2">
                            <form asp-action="Cancel" asp-route-id="@Model.Id" onsubmit="return confirm('Are you sure you want to completely cancel this tender? No one will be able to bid.');">
                                <button type="submit" class="btn btn-outline-danger"><i class="fas fa-ban me-1"></i> Cancel Tender</button>
                            </form>
                            <form asp-action="Close" asp-route-id="@Model.Id" onsubmit="return confirm('Are you sure you want to manually close this tender to new bids?');">
                                <button type="submit" class="btn btn-warning"><i class="fas fa-lock me-1"></i> Close Early</button>
                            </form>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Action / Bids Sidebar -->
        <div class="col-lg-4">
            
            @if (Context.Session.GetString("UserRole") == "Supplier")
            {
                <div class="card shadow-sm border-0 bg-primary text-white mb-4">
                    <div class="card-body p-4 text-center">
                        <h5 class="fw-bold mb-3">Interested in this Order?</h5>
                        <p class="mb-4 text-white-50">Submit a competitive bid detailing your price and delivery timeline.</p>
                        
                        @if (Model.Status == "Open" && Model.ClosingDate >= DateTime.Today)
                        {
                            var hasBid = Model.Bids?.Any(b => b.SupplierId.ToString() == Context.Session.GetString("UserId")) ?? false;
                            if (hasBid)
                            {
                                <div class="alert alert-light text-success fw-bold p-3 mb-0">
                                    <i class="fas fa-check-circle me-2"></i> You have already submitted a bid for this tender.
                                </div>
                            }
                            else
                            {
                                <a asp-controller="Bid" asp-action="Submit" asp-route-tenderId="@Model.Id" class="btn btn-light btn-lg w-100 text-primary fw-bold shadow-sm">
                                    <i class="fas fa-gavel me-2"></i> Submit Bid Now
                                </a>
                            }
                        }
                        else
                        {
                            <div class="alert alert-light text-danger fw-bold p-3 mb-0">
                                <i class="fas fa-lock me-2"></i> This tender is no longer accepting bids.
                            </div>
                        }
                    </div>
                </div>
                
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-white py-3">
                        <h6 class="mb-0 fw-bold">Retailer Information</h6>
                    </div>
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            <div class="bg-light rounded-circle p-3 me-3 text-primary">
                                <i class="fas fa-building fa-lg"></i>
                            </div>
                            <div>
                                <h6 class="fw-bold mb-0">@Model.Retailer?.BusinessName</h6>
                            </div>
                        </div>
                    </div>
                </div>
            }

            @if (Context.Session.GetString("UserRole") == "Retailer")
            {
                <div class="card shadow-sm border-0 mb-4">
                    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
                        <h6 class="mb-0 fw-bold"><i class="fas fa-gavel text-primary me-2"></i>Received Bids</h6>
                        <span class="badge bg-primary rounded-pill">@(Model.Bids?.Count ?? 0)</span>
                    </div>
                    <div class="card-body p-0">
                        @if (Model.Bids != null && Model.Bids.Any())
                        {
                            <div class="list-group list-group-flush">
                                @foreach (var bid in Model.Bids.OrderBy(b => b.BidAmount))
                                {
                                    <div class="list-group-item p-3 border-bottom position-relative">
                                        <div class="d-flex justify-content-between align-items-start mb-2">
                                            <div class="fw-bold text-dark">@bid.Supplier?.CompanyName</div>
                                            
                                            @if (bid.Status == "Accepted") { <span class="badge bg-success">Accepted</span> }
                                            else if (bid.Status == "Rejected") { <span class="badge bg-danger">Rejected</span> }
                                            else { <span class="badge bg-warning text-dark">Pending</span> }
                                        </div>
                                        <div class="d-flex justify-content-between text-muted small">
                                            <span>Unit Price:</span>
                                            <span class="fw-bold text-dark">@bid.BidAmount.ToString("C")</span>
                                        </div>
                                        <div class="d-flex justify-content-between text-muted small mt-1">
                                            <span>Delivery:</span>
                                            <span class="text-dark">@bid.DeliveryTimeline</span>
                                        </div>
                                    </div>
                                }
                            </div>
                            
                            @if (Model.Status == "Open" || Model.Status == "Closed")
                            {
                                <div class="p-3 bg-light border-top text-center">
                                    <a asp-controller="Bid" asp-action="Review" asp-route-tenderId="@Model.Id" class="btn btn-primary w-100 fw-bold">
                                        Review & Compare Bids
                                    </a>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="p-4 text-center text-muted">
                                <i class="fas fa-inbox fa-3x mb-3 opacity-50"></i>
                                <p class="mb-0">No bids have been submitted yet.</p>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    </div>
</div>
