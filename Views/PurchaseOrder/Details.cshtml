@model SCM_System.Models.Entities.PurchaseOrder
@using Microsoft.AspNetCore.Http

@{
    ViewData["Title"] = "Purchase Order Details";
    var userRole = Context.Session.GetString("UserRole");
    var isSupplier = userRole == "Supplier";
    var isRetailer = userRole == "Retailer";
}

<div class="container mt-4 mb-5">
    <div class="mb-4">
        <a asp-action="Index" class="btn btn-light shadow-sm text-dark px-4 rounded-pill border fw-medium">
            <i class="fas fa-arrow-left me-2 text-primary"></i> Back to Orders
        </a>
    </div>

    <div class="row g-4">
        <div class="col-lg-8">
            <div class="card shadow rounded-4 border-0 mb-4 overflow-hidden position-relative" style="border-top: 6px solid @(Model.Status == "Accepted" ? "#10b981" : Model.Status == "Rejected" || Model.Status == "Cancelled" ? "#ef4444" : "#f59e0b");">
                
                <!-- Background Decoration -->
                <div class="position-absolute top-0 end-0 opacity-10 p-4" style="z-index: 0; transform: translate(10%, -20%) scale(1.5);">
                    <i class="fas fa-file-invoice text-secondary" style="font-size: 15rem;"></i>
                </div>

                <div class="card-header bg-white d-flex flex-column flex-sm-row justify-content-between align-items-sm-center py-4 border-bottom position-relative" style="z-index: 1;">
                    <div class="mb-3 mb-sm-0">
                        <span class="text-uppercase tracking-wide text-muted fw-bold fs-7 mb-1 d-block">Purchase Order</span>
                        <h2 class="mb-0 fw-bold font-monospace text-dark d-flex align-items-center">
                            @Model.PONumber
                        </h2>
                        <div class="text-muted mt-2 d-flex align-items-center">
                            <i class="fas fa-calendar-alt me-2 text-primary"></i> 
                            Issued on <span class="fw-medium text-dark ms-1">@Model.OrderDate.ToString("MMMM dd, yyyy")</span>
                        </div>
                    </div>
                    <div>
                        @if (Model.Status == "Pending")
                        {
                            <span class="badge rounded-pill bg-warning bg-opacity-10 text-warning border-warning border px-4 py-2 fs-6 shadow-sm"><i class="fas fa-hourglass-half me-2"></i> PENDING</span>
                        }
                        else if (Model.Status == "Accepted")
                        {
                            <span class="badge rounded-pill bg-success bg-opacity-10 text-success border-success border px-4 py-2 fs-6 shadow-sm"><i class="fas fa-check-circle me-2"></i> ACCEPTED</span>
                        }
                        else if (Model.Status == "Rejected")
                        {
                            <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger border-danger border px-4 py-2 fs-6 shadow-sm"><i class="fas fa-times-circle me-2"></i> REJECTED</span>
                        }
                        else
                        {
                            <span class="badge rounded-pill bg-secondary bg-opacity-10 text-secondary border-secondary border px-4 py-2 fs-6 shadow-sm"><i class="fas fa-ban me-2"></i> CANCELLED</span>
                        }
                    </div>
                </div>

                <div class="card-body px-4 py-5 position-relative" style="z-index: 1;">
                    <!-- Parties Information Cards -->
                    <div class="row mb-5 g-4 align-items-stretch">
                        <!-- Retailer Details -->
                        <div class="col-md-5">
                            <div class="h-100 p-4 rounded-4 bg-light bg-opacity-50 border">
                                <div class="d-flex align-items-center mb-3 border-bottom pb-3">
                                    <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3">
                                        <i class="fas fa-store text-primary fs-5"></i>
                                    </div>
                                    <div>
                                        <h6 class="text-muted text-uppercase tracking-wide fw-bold fs-7 mb-0">Purchaser (Retailer)</h6>
                                    </div>
                                </div>
                                <h5 class="fw-bold mb-3 text-dark">@Model.Retailer?.BusinessName</h5>
                                <ul class="list-unstyled text-muted small mb-0 d-flex flex-column gap-2">
                                    <li class="d-flex align-items-center"><i class="fas fa-envelope fw-normal text-muted me-3 w-15px text-center"></i><span class="text-dark">@Model.Retailer?.User?.Email</span></li>
                                    <li class="d-flex align-items-center"><i class="fas fa-phone fw-normal text-muted me-3 w-15px text-center"></i><span class="text-dark">@Model.Retailer?.User?.PhoneNumber</span></li>
                                    <li class="d-flex align-items-center"><i class="fas fa-map-marker-alt fw-normal text-muted me-3 w-15px text-center"></i><span class="text-dark">@Model.Retailer?.City</span></li>
                                </ul>
                            </div>
                        </div>
                        
                        <!-- Connection Arrow -->
                        <div class="col-md-2 d-flex justify-content-center align-items-center">
                            <div class="bg-white rounded-circle shadow-sm border p-3 d-none d-md-flex align-items-center justify-content-center" style="width: 50px; height: 50px;">
                                <i class="fas fa-arrow-right text-primary"></i>
                            </div>
                        </div>

                        <!-- Supplier Details -->
                        <div class="col-md-5">
                            <div class="h-100 p-4 rounded-4 bg-light bg-opacity-50 border">
                                <div class="d-flex align-items-center mb-3 border-bottom pb-3">
                                    <div class="bg-success bg-opacity-10 p-3 rounded-circle me-3">
                                        <i class="fas fa-industry text-success fs-5"></i>
                                    </div>
                                    <div>
                                        <h6 class="text-muted text-uppercase tracking-wide fw-bold fs-7 mb-0">Vendor (Supplier)</h6>
                                    </div>
                                </div>
                                <h5 class="fw-bold text-dark mb-3">@Model.Supplier?.CompanyName</h5>
                                <ul class="list-unstyled text-muted small mb-0 d-flex flex-column gap-2">
                                    <li class="d-flex align-items-center"><i class="fas fa-envelope fw-normal text-muted me-3 w-15px text-center"></i><span class="text-dark">@Model.Supplier?.User?.Email</span></li>
                                    <li class="d-flex align-items-center"><i class="fas fa-phone fw-normal text-muted me-3 w-15px text-center"></i><span class="text-dark">@Model.Supplier?.User?.PhoneNumber</span></li>
                                    <li class="d-flex align-items-center"><i class="fas fa-map-marker-alt fw-normal text-muted me-3 w-15px text-center"></i><span class="text-dark">@Model.Supplier?.City</span></li>
                                </ul>
                            </div>
                        </div>
                    </div>

                    <!-- Line Items Table -->
                    <div class="d-flex align-items-center mb-3">
                        <i class="fas fa-box-open text-primary fs-5 me-2"></i>
                        <h5 class="fw-bold mb-0 text-dark">Order Content</h5>
                    </div>
                    
                    <div class="table-responsive border rounded-4 shadow-sm overflow-hidden">
                        <table class="table table-borderless table-hover mb-0">
                            <thead class="bg-light border-bottom">
                                <tr>
                                    <th class="py-3 px-4 text-uppercase text-muted fs-7 fw-bold tracking-wide">Product Information</th>
                                    <th class="text-center py-3 px-4 text-uppercase text-muted fs-7 fw-bold tracking-wide">Unit Price</th>
                                    <th class="text-center py-3 px-4 text-uppercase text-muted fs-7 fw-bold tracking-wide">Quantity</th>
                                    <th class="text-end py-3 px-4 text-uppercase text-muted fs-7 fw-bold tracking-wide">Line Total</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr class="border-bottom">
                                    <td class="px-4 py-4">
                                        <div class="d-flex align-items-center">
                                            <div class="bg-primary bg-opacity-10 text-primary rounded p-3 me-3 d-flex align-items-center border border-primary border-opacity-25">
                                                <i class="fas fa-cube fa-lg"></i>
                                            </div>
                                            <div>
                                                <div class="fw-bold text-dark fs-5">@Model.ProductName</div>
                                                <div class="small text-muted mt-1">Item ID: @Model.ProductId</div>
                                            </div>
                                        </div>
                                    </td>
                                    <td class="text-center px-4 py-4 align-middle fs-5">@Model.UnitPrice.ToString("C")</td>
                                    <td class="text-center px-4 py-4 align-middle">
                                        <span class="badge bg-light text-dark border px-3 py-2 fs-6">@Model.Quantity Units</span>
                                    </td>
                                    <td class="text-end fw-bold px-4 py-4 align-middle fs-5 text-dark">@((Model.UnitPrice * Model.Quantity).ToString("C"))</td>
                                </tr>
                            </tbody>
                            <tfoot class="bg-light bg-opacity-50">
                                <tr>
                                    <td colspan="2" class="py-3 border-top"></td>
                                    <td class="text-end fw-bold py-4 text-uppercase text-muted tracking-wide align-middle border-top">Total Amount Due:</td>
                                    <td class="text-end fw-bold py-4 px-4 fs-3 text-success align-middle border-top">@Model.TotalAmount.ToString("C")</td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>

                @if (Model.Status == "Pending")
                {
                    <div class="card-footer bg-light bg-opacity-50 border-top p-4 d-flex justify-content-end gap-3 rounded-bottom-4">
                        @if (isSupplier)
                        {
                            <!-- Supplier Actions -->
                            <form asp-action="Reject" asp-route-id="@Model.Id" class="w-100 mw-25">
                                <button type="submit" class="btn btn-outline-danger btn-lg w-100 fw-bold rounded-pill" onclick="return confirm('Are you sure you want to REJECT this Purchase Order?');">
                                    <i class="fas fa-times me-2"></i> Reject Order
                                </button>
                            </form>
                            <form asp-action="Accept" asp-route-id="@Model.Id" class="w-100 mw-25">
                                <button type="submit" class="btn btn-success btn-lg w-100 fw-bold shadow-sm rounded-pill hover-lift" onclick="return confirm('By accepting, you commit to fulfilling this order. A final fulfillment Order record will be automatically generated.');">
                                    <i class="fas fa-check-circle me-2"></i> Accept Order
                                </button>
                            </form>
                        }
                        
                        @if (isRetailer)
                        {
                            <!-- Retailer Actions -->
                            <form asp-action="Cancel" asp-route-id="@Model.Id" class="w-100 mw-25">
                                <button type="submit" class="btn btn-outline-danger btn-lg w-100 fw-bold rounded-pill" onclick="return confirm('Are you sure you want to CANCEL this pending Purchase Order?');">
                                    <i class="fas fa-ban me-2"></i> Cancel Order
                                </button>
                            </form>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="col-lg-4">
            <!-- Order Context panel -->
            <div class="card shadow-sm border-0 mb-4 rounded-4 overflow-hidden">
                <div class="card-header bg-white py-3 border-bottom">
                    <h6 class="mb-0 fw-bold text-uppercase text-muted tracking-wide fs-7"><i class="fas fa-info-circle text-primary me-2"></i> Order Context</h6>
                </div>
                <div class="card-body p-4 bg-light bg-opacity-25">
                    @if (Model.TenderBidId != null)
                    {
                        <div class="bg-white border rounded-4 p-4 shadow-sm position-relative overflow-hidden">
                            <div class="position-absolute top-0 start-0 w-100" style="height: 4px; background: linear-gradient(90deg, var(--bs-primary), var(--bs-info));"></div>
                            <div class="d-flex align-items-center mb-2">
                                <div class="bg-primary bg-opacity-10 p-2 rounded text-primary me-3">
                                    <i class="fas fa-gavel fa-fw"></i>
                                </div>
                                <h6 class="fw-bold text-dark mb-0">Tender Process</h6>
                            </div>
                            <p class="small text-muted mb-0 mt-3 ms-1">This Purchase Order was automatically generated because the Retailer awarded the Supplier's winning bid.</p>
                            
                            @if (isRetailer)
                            {
                                <a asp-controller="Tender" asp-action="Details" asp-route-id="@Model.TenderBid.TenderId" class="btn btn-outline-primary btn-sm mt-4 w-100 rounded-pill fw-medium">
                                    View Original Tender <i class="fas fa-arrow-right ms-1 fs-7"></i>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="bg-white border rounded-4 p-4 shadow-sm position-relative overflow-hidden">
                            <div class="position-absolute top-0 start-0 w-100" style="height: 4px; background: linear-gradient(90deg, var(--bs-success), #10b981));"></div>
                            <div class="d-flex align-items-center mb-2">
                                <div class="bg-success bg-opacity-10 p-2 rounded text-success me-3">
                                    <i class="fas fa-store fa-fw"></i>
                                </div>
                                <h6 class="fw-bold text-dark mb-0">Direct Purchase</h6>
                            </div>
                            <p class="small text-muted mb-0 mt-3 ms-1">This Purchase Order was generated directly from the Marketplace catalog.</p>
                        </div>
                    }
                </div>
            </div>

            <!-- Follow-up System panel -->
            @if (Model.Status == "Accepted")
            {
                <div class="card shadow-sm border-0 rounded-4 overflow-hidden position-relative" style="background: linear-gradient(135deg, var(--bs-primary) 0%, #3b82f6 100%);">
                    <div class="position-absolute end-0 bottom-0 opacity-25 p-3" style="transform: rotate(-15deg) scale(2);">
                        <i class="fas fa-truck-loading text-white" style="font-size: 8rem;"></i>
                    </div>
                    
                    <div class="card-body p-4 p-xl-5 text-center text-white position-relative" style="z-index: 1;">
                        <div class="bg-white bg-opacity-25 rounded-circle d-inline-flex align-items-center justify-content-center mb-4" style="width: 80px; height: 80px; backdrop-filter: blur(5px);">
                            <i class="fas fa-box fa-2x"></i>
                        </div>
                        <h4 class="fw-bold text-white mb-3">Fulfillment Active</h4>
                        <p class="text-white text-opacity-75 mb-4 px-2">An official fulfillment Order track has been created for this PO.</p>
                        
                        <a asp-controller="Order" asp-action="Index" class="btn btn-light w-100 fw-bold text-primary rounded-pill py-2 shadow-sm hover-lift">
                            Track Fulfillment <i class="fas fa-arrow-right ms-2 fs-7"></i>
                        </a>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .mw-25 { max-width: 250px; }
    .fs-7 { font-size: 0.75rem; }
    .w-15px { width: 15px; }
    .tracking-wide { letter-spacing: 0.05em; }
    
    .hover-lift {
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .hover-lift:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 20px -10px rgba(0,0,0,0.15) !important;
    }
</style>
